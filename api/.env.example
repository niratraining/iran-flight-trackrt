# این فایل رو کپی نکن و مستقیم دیپلوی نکن — فقط راهنماست.
# مقادیر واقعی رو در پنل لیارا > برنامه > تنظیمات > Environment Variables وارد کن.

# --- MongoDB (دیتابیس لیارا) ---
# از صفحه‌ی "نحوه اتصال" دیتابیس Mongo روی لیارا کپی کن. اگه اپ و
# دیتابیس هر دو روی لیارا و توی یک شبکه‌ی خصوصی‌ان، از لینک شبکه‌ی
# خصوصی استفاده کن (سریع‌تر و بدون هزینه ترافیک).
MONGODB_URI=mongodb://root:PASSWORD@HOST:PORT/flighttrack?authSource=admin
MONGODB_DB=flighttrack

# --- توکن پنل مدیریت + رفرش دستی ---
REFRESH_SECRET=یک-رشته-تصادفی-طولانی-اینجا

# --- آدرس fids-relay (همون appی که از قبل روی لیارا هست) ---
FIDS_RELAY_URL=https://fids-relay.liara.run

# --- کلیدهای aviationstack (فقط برای IKA/KIH/ZBR که fids پوشش نمی‌ده) ---
AVIATIONSTACK_KEY=
AVIATIONSTACK_KEY1=
AVIATIONSTACK_KEY2=
# ... تا AVIATIONSTACK_KEY11 (جمعاً ۱۲ اسلات، هرکدوم رو نخواستی خالی بذار)

# --- CORS: آدرس(های) داشبورد، کاما-جدا. اگه ندی، پیش‌فرض همون دو تا قبلیه ---
ALLOWED_ORIGINS=https://flight-track.travellab.ir
